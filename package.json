{
  "name": "pass-emploi-connect",
  "private": true,
  "version": "2.1.3",
  "license": "CEJ",
  "engines": {
    "node": "22.14.0"
  },
  "scripts": {
    "build": "nest build",
    "prepare": "husky install",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint --ext \".ts\" --ignore-path .gitignore .",
    "lint:fix": "eslint --ext \".ts\" --fix --ignore-path .gitignore .",
    "start": "nest start",
    "watch": "nest start --watch | npx pino-pretty",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --enable-source-maps dist/main",
    "start:redis:db": "docker compose up -d redis",
    "test:local": "yarn start:redis:db && REDIS_URL=redis://:myredispassword@redis:6379/0 vitest run",
    "cover": "yarn test:local --coverage",
    "cover:report": "vitest run --coverage",
    "test": "yarn cover",
    "test:ci": "vitest run --coverage",
    "seed:migration-test": "tsx src/scripts/seed-migration-test.ts",
    "cleanup:migration-test": "tsx src/scripts/cleanup-migration-test.ts",
    "generate-key-pair": "node scripts/generate-key-pair.mjs",
    "release:patch": "scripts/release-version.sh patch",
    "release:minor": "scripts/release-version.sh minor",
    "release:major": "scripts/release-version.sh major"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "11.1.13",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "@types/oidc-provider": "^9.0.0",
    "@types/pino-multi-stream": "^5.1.6",
    "@types/sanitize-html": "^2.11.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.5",
    "elastic-apm-node": "3.52.2",
    "ioredis": "^5.3.2",
    "joi": "^18.0.0",
    "jose": "^5.2.4",
    "luxon": "^3.4.4",
    "nestjs-pino": "^4.0.0",
    "oidc-provider": "^9.2.0",
    "openid-client": "^5.6.5",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.13.0",
    "swagger-ui-express": "^5.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^6.0.2",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@salesforce/ts-sinon": "^1.4.19",
    "@types/sinon": "^17.0.3",
    "@types/supertest": "^7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dotvault": "^0.0.9",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^9.0.11",
    "lint-staged": "^16.0.0",
    "nock": "^14.0.0",
    "npm-check-updates": "^19.2.0",
    "prettier": "^2.8.0",
    "sinon": "^21.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.ts": "yarn lint:fix"
  },
  "packageManager": "yarn@4.9.3",
  "resolutions": {
    "cross-spawn": "7.0.6",
    "glob": "^9.3.5"
  }
}
